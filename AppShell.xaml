<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="doanC_.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:doanC_"
    xmlns:views="clr-namespace:doanC_.Views"
    Title="doanC_"
    TabBarBackgroundColor="White"
    TabBarForegroundColor="#C8A882"
    TabBarUnselectedColor="#9E8B7E"
    TabBarTitleColor="#C8A882">

    <Shell.Resources>
        <ResourceDictionary>
            <FontImageSource x:Key="MapIcon" FontFamily="FontAwesome" Glyph="&#xf279;" Color="#C8A882"/>
            <FontImageSource x:Key="PoiIcon" FontFamily="FontAwesome" Glyph="&#xf041;" Color="#C8A882"/>
            <FontImageSource x:Key="QrIcon" FontFamily="FontAwesome" Glyph="&#xf029;" Color="#C8A882"/>
            <FontImageSource x:Key="SettingsIcon" FontFamily="FontAwesome" Glyph="&#xf013;" Color="#C8A882"/>
        </ResourceDictionary>
    </Shell.Resources>

    <TabBar>
        <!-- Bản đồ -->
        <ShellContent
            Title="Bản đồ"
            Icon="{StaticResource MapIcon}"
            ContentTemplate="{DataTemplate views:MapPage}"
            Route="MapPage" />

        <!-- Điểm -->
        <ShellContent
            Title="Điểm"
            Icon="{StaticResource PoiIcon}"
            ContentTemplate="{DataTemplate views:PoiListPage}"
            Route="PoiListPage" />

        <!-- QR -->
        <ShellContent
            Title="QR"
            Icon="{StaticResource QrIcon}"
            ContentTemplate="{DataTemplate views:QrScannerPage}"
            Route="QrScannerPage" />

        <!-- Cài đặt -->
        <ShellContent
            Title="Cài đặt"
            Icon="{StaticResource SettingsIcon}"
            ContentTemplate="{DataTemplate views:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

</Shell>
